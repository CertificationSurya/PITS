@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<h2>Login</h2>

<form method="post">
    <div class="mb-3">
        <label>Email</label>
        <input type="email" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Password</label>
        <input type="password" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Login</button>
</form>